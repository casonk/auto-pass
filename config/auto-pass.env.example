# auto-pass loads config/auto-pass.env.local automatically when the CLI runs.
# Shell-exported values still win, so you can override anything here per command.
#
# This example uses named profiles because you said you have multiple KeePass
# databases. Set AUTO_PASS_PROFILE to the profile you want active.

AUTO_PASS_PROFILE=personal

# Optional direct values for a single active database.
# AUTO_PASS_KEEPASSXC_DB_PATH=/path/to/default.kdbx
# AUTO_PASS_KEEPASSXC_DB_PASSWORD=replace-me
# AUTO_PASS_KEEPASSXC_KEY_FILE=

# personal profile
AUTO_PASS_PROFILE_PERSONAL_KEEPASSXC_DB_PATH=/path/to/personal.kdbx
AUTO_PASS_PROFILE_PERSONAL_KEEPASSXC_DB_PASSWORD=replace-me-personal
AUTO_PASS_PROFILE_PERSONAL_KEEPASSXC_KEY_FILE=

# work profile
AUTO_PASS_PROFILE_WORK_KEEPASSXC_DB_PATH=/path/to/work.kdbx
AUTO_PASS_PROFILE_WORK_KEEPASSXC_DB_PASSWORD=replace-me-work
AUTO_PASS_PROFILE_WORK_KEEPASSXC_KEY_FILE=

# infra profile
AUTO_PASS_PROFILE_INFRA_KEEPASSXC_DB_PATH=/path/to/infra.kdbx
AUTO_PASS_PROFILE_INFRA_KEEPASSXC_DB_PASSWORD=replace-me-infra
AUTO_PASS_PROFILE_INFRA_KEEPASSXC_KEY_FILE=

# Optional: audit password-bearing reads through the sibling shock-relay repo.
# Set at least one recipient to activate a channel. The notification body
# contains metadata only, never the secret value itself.
# AUTO_PASS_NOTIFY_PASSWORD_RETRIEVAL=1
# AUTO_PASS_NOTIFY_PASSWORD_RETRIEVAL_EVERY_N=3
# AUTO_PASS_NOTIFY_PASSWORD_RETRIEVAL_EMAIL_TO=alerts@example.com
# AUTO_PASS_NOTIFY_PASSWORD_RETRIEVAL_SIGNAL_TO=note-to-self
# AUTO_PASS_NOTIFY_PASSWORD_RETRIEVAL_SUBJECT_PREFIX=[auto-pass]
# AUTO_PASS_NOTIFY_SHOCK_RELAY_ROOT=/path/to/shock-relay
# AUTO_PASS_NOTIFY_SHOCK_RELAY_EMAIL_CONFIG=/path/to/shock-relay/services/gmail-imap/config.local.yaml
# AUTO_PASS_NOTIFY_SHOCK_RELAY_SIGNAL_CONFIG=/path/to/shock-relay/services/signal-cli/config.local.yaml
#
# Set DAILY_SUMMARY=1 to switch from per-retrieval emails to a once-daily digest.
# Each retrieval is appended to a JSONL log instead of being sent immediately.
# Schedule `auto-pass notify-summary` daily (via systemd timer or cron) to send
# the digest and clear the log.  The per-retrieval code paths stay in place but
# are bypassed when this flag is set.
# AUTO_PASS_NOTIFY_DAILY_SUMMARY=1
# AUTO_PASS_NOTIFY_DAILY_LOG_PATH=~/.cache/auto-pass/retrieval_log.jsonl

# --- Provisioning service (auto-pass serve) ---
# The daemon holds the KeePassXC master password in memory after `auto-pass unlock`
# and serves pre-approved credentials to local repos over a Unix socket.
# Repos in the allowlist never need to store or know the database password.
#
# Socket path for the daemon (default: ~/.cache/auto-pass/provisioning.sock).
# AUTO_PASS_PROVISIONING_SOCKET=~/.cache/auto-pass/provisioning.sock
#
# Allowlist TOML file (default: config/provisioning-allowlist.local.toml).
# Copy config/provisioning-allowlist.example.toml to .local.toml and edit it.
# AUTO_PASS_PROVISIONING_ALLOWLIST=config/provisioning-allowlist.local.toml
#
# Web UI token (required to start auto-pass web). Use a strong random value.
# AUTO_PASS_WEB_TOKEN=replace-with-a-strong-random-token
