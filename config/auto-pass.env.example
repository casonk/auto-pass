# auto-pass loads config/auto-pass.env.local automatically when the CLI runs.
# Shell-exported values still win, so you can override anything here per command.
#
# This example uses named profiles because you said you have multiple KeePass
# databases. Set AUTO_PASS_PROFILE to the profile you want active.

AUTO_PASS_PROFILE=personal

# Optional direct values for a single active database.
# AUTO_PASS_KEEPASSXC_DB_PATH=/path/to/default.kdbx
# AUTO_PASS_KEEPASSXC_DB_PASSWORD=replace-me
# AUTO_PASS_KEEPASSXC_KEY_FILE=

# personal profile
AUTO_PASS_PROFILE_PERSONAL_KEEPASSXC_DB_PATH=/path/to/personal.kdbx
AUTO_PASS_PROFILE_PERSONAL_KEEPASSXC_DB_PASSWORD=replace-me-personal
AUTO_PASS_PROFILE_PERSONAL_KEEPASSXC_KEY_FILE=

# work profile
AUTO_PASS_PROFILE_WORK_KEEPASSXC_DB_PATH=/path/to/work.kdbx
AUTO_PASS_PROFILE_WORK_KEEPASSXC_DB_PASSWORD=replace-me-work
AUTO_PASS_PROFILE_WORK_KEEPASSXC_KEY_FILE=

# infra profile
AUTO_PASS_PROFILE_INFRA_KEEPASSXC_DB_PATH=/path/to/infra.kdbx
AUTO_PASS_PROFILE_INFRA_KEEPASSXC_DB_PASSWORD=replace-me-infra
AUTO_PASS_PROFILE_INFRA_KEEPASSXC_KEY_FILE=

